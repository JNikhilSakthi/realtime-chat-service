# Copy to .env and adjust as needed. docker-compose picks these up automatically.

DB_NAME=chatdb
DB_USERNAME=chatuser
DB_PASSWORD=chatpass
DB_ROOT_PASSWORD=rootpass

# Comma-separated list of origins allowed to connect to the REST API / WebSocket endpoint.
# Use "*" for local development; set to your real client origin(s) in production.
CHAT_ALLOWED_ORIGINS=*
